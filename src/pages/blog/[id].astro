---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { id: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — Trite Site`}>
	<article>
		<header>
			<span class="kicker mono">{post.data.tags[0] ?? 'DISPATCH'}</span>
			<h1>{post.data.title}</h1>
			<div class="byline-row">
				<p class="dateline mono">
					<time datetime={post.data.pubDate.toISOString()}>
						{post.data.pubDate.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
							timeZone: 'UTC',
						})}
					</time>
					{post.data.tags.length > 1 && <span> &middot; {post.data.tags.slice(1).join(', ')}</span>}
				</p>
				<div class="stamp" aria-hidden="true">
					<span>Certified</span>
					<span>True</span>
				</div>
			</div>
		</header>
		<div class="prose">
			<Content />
		</div>
	</article>
	<p class="back mono"><a href="../../">&larr; Back to the front page</a></p>
</BaseLayout>

<style>
	article header {
		margin-bottom: 2rem;
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--rule);
	}

	.kicker {
		display: block;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.09em;
		color: var(--stamp-dim);
		margin-bottom: 0.5rem;
	}

	h1 {
		font-size: clamp(2rem, 6vw, 2.9rem);
		margin: 0 0 1rem;
	}

	.byline-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.dateline {
		font-size: 0.78rem;
		color: var(--ink-soft);
		text-transform: uppercase;
		letter-spacing: 0.03em;
		margin: 0;
	}

	.stamp {
		display: inline-flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		width: 5.5rem;
		height: 5.5rem;
		border: 3px solid var(--stamp);
		border-radius: 50%;
		outline: 1px solid var(--stamp);
		outline-offset: 3px;
		transform: rotate(-9deg);
		color: var(--stamp);
		font-family: var(--font-mono);
		font-weight: 700;
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.04em;
		line-height: 1.3;
		text-align: center;
		flex-shrink: 0;
	}

	.back {
		margin-top: 3rem;
		font-size: 0.85rem;
	}

	.back a {
		text-decoration: none;
	}

	.back a:hover {
		text-decoration: underline;
	}
</style>
