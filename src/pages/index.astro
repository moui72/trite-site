---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Trite Site — the greatest website of all time">
	<ul class="front-page">
		{
			posts.map((post) => (
				<li>
					<a class="story" href={`blog/${post.id}/`}>
						<span class="kicker mono">{post.data.tags[0] ?? 'DISPATCH'}</span>
						<span class="headline">{post.data.title}</span>
						<span class="dateline mono">
							<time datetime={post.data.pubDate.toISOString()}>
								{post.data.pubDate.toLocaleDateString('en-US', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
									timeZone: 'UTC',
								})}
							</time>
							{post.data.tags.length > 1 && <span class="dateline-tags"> — {post.data.tags.slice(1).join(', ')}</span>}
						</span>
					</a>
				</li>
			))
		}
	</ul>
</BaseLayout>

<style>
	.front-page {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 3px double var(--ink);
	}

	.story {
		display: block;
		padding: 1.4rem 0;
		border-bottom: 1px solid var(--rule);
		text-decoration: none;
		color: inherit;
	}

	.kicker {
		display: block;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.09em;
		color: var(--stamp-dim);
		margin-bottom: 0.35rem;
	}

	.headline {
		display: block;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(1.4rem, 3.6vw, 1.75rem);
		line-height: 1.12;
		color: var(--ink);
	}

	.story:hover .headline,
	.story:focus-visible .headline {
		color: var(--stamp-dim);
	}

	.dateline {
		display: block;
		margin-top: 0.5rem;
		font-size: 0.72rem;
		color: var(--ink-soft);
		text-transform: uppercase;
		letter-spacing: 0.03em;
	}

	.dateline-tags {
		text-transform: none;
		letter-spacing: normal;
	}
</style>
