---
interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Trite Site — the greatest website of all time.' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="/">Trite Site</a>
			<nav>
				<a href="/">Home</a>
				<a href="/about/">About</a>
			</nav>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<p>
				Restored from the
				<a href="https://web.archive.org/web/20180902000000*/trite.site" target="_blank" rel="noopener">Wayback Machine</a>
				after the original content was lost. Not actually true. Probably.
			</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--ink: #1a1a1a;
		--paper: #fdfaf3;
		--accent: #b3401e;
		--muted: #6b6459;
		font-family: 'Georgia', 'Times New Roman', serif;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
	}

	body {
		background: var(--paper);
		color: var(--ink);
		line-height: 1.65;
	}

	.site-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem 1.25rem 1rem;
		border-bottom: 3px double var(--ink);
	}

	.brand {
		font-size: 1.75rem;
		font-weight: bold;
		letter-spacing: 0.02em;
		color: var(--ink);
		text-decoration: none;
		text-transform: uppercase;
	}

	.site-header nav a {
		margin-left: 1.25rem;
		color: var(--muted);
		text-decoration: none;
		font-size: 0.95rem;
	}

	.site-header nav a:hover {
		color: var(--accent);
		text-decoration: underline;
	}

	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem 1.25rem 4rem;
	}

	a {
		color: var(--accent);
	}

	h1,
	h2,
	h3 {
		line-height: 1.25;
	}

	img {
		max-width: 100%;
		height: auto;
	}

	blockquote {
		border-left: 3px solid var(--accent);
		margin-left: 0;
		padding-left: 1rem;
		color: var(--muted);
	}

	.site-footer {
		max-width: 720px;
		margin: 0 auto;
		padding: 1.5rem 1.25rem 3rem;
		color: var(--muted);
		font-size: 0.85rem;
		border-top: 1px solid #ddd6c7;
	}
</style>
