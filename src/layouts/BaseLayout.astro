---
import '@fontsource/anton';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';
import '@fontsource/newsreader/400.css';
import '@fontsource/newsreader/400-italic.css';
import '@fontsource/newsreader/600.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Trite Site — the greatest website of all time.' } = Astro.props;

const depth = Astro.url.pathname.split('/').filter(Boolean).length;
const root = '../'.repeat(depth);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${root}favicon.svg`} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<header class="masthead">
			<div class="masthead-inner">
				<a class="nameplate" href={root || '.'}>TRITE SITE</a>
				<p class="motto">All the news that's barely fit to print.</p>
				<nav>
					<a href={root || '.'}>Front Page</a>
					<a href={`${root}about/`}>Masthead &amp; Ethics</a>
				</nav>
			</div>
		</header>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<p>Trite Site is satire. No claim on this publication should be believed, cited, or repeated in mixed company.</p>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--paper: #fcfffc;
		--ink: #040f0f;
		--ink-soft: #33413f;
		--panel: #2d3a3a;
		--stamp: #2ba84a;
		--stamp-dim: #248232;
		--rule: #cfd8d3;

		--font-display: 'Anton', 'Arial Narrow', sans-serif;
		--font-serif: 'Newsreader', Georgia, 'Times New Roman', serif;
		--font-mono: 'JetBrains Mono', ui-monospace, 'SF Mono', Menlo, monospace;
	}

	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
	}

	body {
		background: var(--paper);
		color: var(--ink);
		font-family: var(--font-serif);
		line-height: 1.65;
		font-size: 1.08rem;
	}

	.masthead {
		background: var(--panel);
		color: var(--paper);
		border-bottom: 5px solid var(--ink);
		box-shadow: 0 3px 0 var(--stamp);
	}

	.masthead-inner {
		max-width: 760px;
		margin: 0 auto;
		padding: 1.75rem 1.25rem 1.1rem;
		display: grid;
		grid-template-columns: 1fr auto;
		column-gap: 1.5rem;
	}

	.nameplate {
		grid-column: 1;
		font-family: var(--font-display);
		font-weight: 400;
		font-size: clamp(2.4rem, 7vw, 3.4rem);
		letter-spacing: 0.01em;
		color: var(--paper);
		text-decoration: none;
		line-height: 1;
	}

	.motto {
		grid-column: 1;
		font-family: var(--font-serif);
		font-style: italic;
		color: var(--stamp);
		margin: 0.5rem 0 0;
		font-size: 0.95rem;
	}

	.masthead nav {
		grid-column: 2;
		align-self: end;
		font-family: var(--font-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
		text-align: right;
		padding-bottom: 0.4rem;
	}

	.masthead nav a {
		color: var(--paper);
		text-decoration: none;
		opacity: 0.85;
	}

	.masthead nav a:hover,
	.masthead nav a:focus-visible {
		color: var(--stamp);
		opacity: 1;
	}

	@media (max-width: 520px) {
		.masthead-inner {
			grid-template-columns: 1fr;
		}
		.masthead nav {
			grid-column: 1;
			flex-direction: row;
			text-align: left;
			padding-top: 0.5rem;
		}
	}

	main {
		max-width: 760px;
		margin: 0 auto;
		padding: 2.5rem 1.25rem 4rem;
	}

	a {
		color: var(--ink);
		text-decoration-color: var(--stamp);
		text-decoration-thickness: 2px;
	}

	a:hover {
		color: var(--stamp-dim);
	}

	h1,
	h2,
	h3 {
		font-family: var(--font-display);
		font-weight: 400;
		line-height: 1.05;
		text-wrap: balance;
		color: var(--ink);
	}

	.mono {
		font-family: var(--font-mono);
	}

	img {
		max-width: 100%;
		height: auto;
		filter: grayscale(0.25) contrast(1.05);
		border: 1px solid var(--ink);
	}

	blockquote {
		border-left: 4px solid var(--stamp);
		margin-left: 0;
		padding-left: 1rem;
		color: var(--ink-soft);
		font-style: italic;
	}

	.share {
		margin-top: 2.5rem;
		padding-top: 1rem;
		border-top: 1px solid var(--rule);
		font-family: var(--font-mono);
		font-size: 0.75rem;
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
		align-items: baseline;
	}

	.share .dim {
		color: var(--stamp-dim);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.share a {
		color: var(--ink-soft);
		text-decoration: none;
	}

	.share a::before {
		content: '[';
		color: var(--stamp-dim);
	}

	.share a::after {
		content: ']';
		color: var(--stamp-dim);
	}

	.share a:hover,
	.share a:focus-visible {
		color: var(--stamp);
	}

	::selection {
		background: var(--stamp);
		color: var(--paper);
	}

	a:focus-visible,
	button:focus-visible,
	input:focus-visible {
		outline: 2px solid var(--stamp);
		outline-offset: 3px;
	}

	.site-footer {
		max-width: 760px;
		margin: 0 auto;
		padding: 1.5rem 1.25rem 3rem;
		color: var(--ink-soft);
		font-family: var(--font-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		border-top: 3px double var(--ink);
	}
</style>
